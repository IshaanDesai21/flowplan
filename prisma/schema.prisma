generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Authentication ───────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  passwordHash String?
  avatarUrl    String?
  isDemo       Boolean  @default(false)
  provider     String   @default("email") // email | google | demo
  googleId     String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions        Session[]
  settings         UserSettings?
  tasks            Task[]
  calendarEvents   CalendarEvent[]
  checklists       Checklist[]
  meetings         Meeting[]
  reminders        Reminder[]
  aiConversations  AIConversation[]
  attachments      Attachment[]

  @@index([email])
  @@index([isDemo])
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Tasks ────────────────────────────────────────────────────

model Task {
  id                String     @id @default(uuid())
  userId            String
  title             String
  description       String?
  dueDate           DateTime?
  dueTime           String?
  priority          TaskPriority @default(MEDIUM)
  category          String?
  status            TaskStatus   @default(NOT_STARTED)
  estimatedDuration Int?         // minutes
  notes             String?
  position          Int          @default(0)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  completedAt       DateTime?

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  reminders   Reminder[]
  attachments Attachment[]

  @@index([userId])
  @@index([dueDate])
  @@index([status])
  @@index([priority])
}

enum TaskStatus {
  NOT_STARTED
  PLANNED
  IN_PROGRESS
  WAITING
  BLOCKED
  COMPLETED
  ARCHIVED
}

enum TaskPriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

// ─── Calendar Events ──────────────────────────────────────────

model CalendarEvent {
  id             String    @id @default(uuid())
  userId         String
  title          String
  description    String?
  startTime      DateTime
  endTime        DateTime
  location       String?
  priority       TaskPriority @default(MEDIUM)
  tags           String[]    @default([])
  status         String       @default("confirmed") // confirmed | tentative | cancelled
  color          String       @default("#6366f1")
  isRecurring    Boolean      @default(false)
  recurrenceRule String?      // RRULE format
  isTimeBlock    Boolean      @default(false)
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  reminders   Reminder[]
  attachments Attachment[]

  @@index([userId])
  @@index([startTime])
  @@index([endTime])
}

// ─── Checklists ───────────────────────────────────────────────

model Checklist {
  id         String    @id @default(uuid())
  userId     String
  title      String
  category   String?
  dueDate    DateTime?
  templateId String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       ChecklistItem[]
  reminders   Reminder[]
  attachments Attachment[]

  @@index([userId])
}

model ChecklistItem {
  id          String   @id @default(uuid())
  checklistId String
  parentId    String?
  title       String
  isCompleted Boolean  @default(false)
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  checklist Checklist      @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  parent    ChecklistItem? @relation("ChecklistItemChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children  ChecklistItem[] @relation("ChecklistItemChildren")

  @@index([checklistId])
  @@index([parentId])
}

model ChecklistTemplate {
  id       String @id @default(uuid())
  name     String
  category String?
  items    Json   // Array of { title, children: [...] }
}

// ─── Meetings ─────────────────────────────────────────────────

model Meeting {
  id           String   @id @default(uuid())
  userId       String
  title        String
  startTime    DateTime
  endTime      DateTime
  participants String[] @default([])
  notes        String?
  actionItems  Json?    // Array of { text, completed }
  location     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  attachments Attachment[]

  @@index([userId])
  @@index([startTime])
}

// ─── Reminders ────────────────────────────────────────────────

model Reminder {
  id             String    @id @default(uuid())
  userId         String
  title          String
  message        String?
  triggerAt      DateTime
  isRecurring    Boolean   @default(false)
  recurrenceRule String?
  type           String    @default("general") // general | task | event | checklist
  method         String    @default("in_app")  // in_app | email | push
  isCompleted    Boolean   @default(false)
  taskId         String?
  eventId        String?
  checklistId    String?
  createdAt      DateTime  @default(now())

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  task      Task?          @relation(fields: [taskId], references: [id], onDelete: SetNull)
  event     CalendarEvent? @relation(fields: [eventId], references: [id], onDelete: SetNull)
  checklist Checklist?     @relation(fields: [checklistId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([triggerAt])
  @@index([isCompleted])
}

// ─── AI Conversations ─────────────────────────────────────────

model AIConversation {
  id        String   @id @default(uuid())
  userId    String
  title     String   @default("New Conversation")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages AIMessage[]

  @@index([userId])
}

model AIMessage {
  id             String   @id @default(uuid())
  conversationId String
  role           String   // user | assistant | system
  content        String
  createdAt      DateTime @default(now())

  conversation AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

// ─── Attachments ──────────────────────────────────────────────

model Attachment {
  id           String   @id @default(uuid())
  userId       String
  fileName     String
  originalName String
  mimeType     String
  fileSize     Int      // bytes
  storagePath  String
  taskId       String?
  eventId      String?
  meetingId    String?
  checklistId  String?
  createdAt    DateTime @default(now())

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  task      Task?          @relation(fields: [taskId], references: [id], onDelete: SetNull)
  event     CalendarEvent? @relation(fields: [eventId], references: [id], onDelete: SetNull)
  meeting   Meeting?       @relation(fields: [meetingId], references: [id], onDelete: SetNull)
  checklist Checklist?     @relation(fields: [checklistId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([taskId])
  @@index([eventId])
  @@index([meetingId])
  @@index([checklistId])
}

// ─── Settings ─────────────────────────────────────────────────

model UserSettings {
  id                  String @id @default(uuid())
  userId              String @unique
  theme               String @default("dark")
  notificationPrefs   Json   @default("{\"inApp\": true, \"email\": false, \"push\": false}")
  productivityPrefs   Json   @default("{\"workStartHour\": 9, \"workEndHour\": 17, \"focusDuration\": 25}")
  googleIntegration   Json   @default("{\"connected\": false}")
  aiSettings          Json   @default("{\"apiKey\": \"\", \"contextLevel\": \"full\"}")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
