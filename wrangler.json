{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "flowplan",
  "compatibility_date": "2024-03-29",
  "routes": [
    {
      "pattern": "flowplan.ftcblueprint.com",
      "custom_domain": true
    }
  ],
  "observability": {
    "enabled": true
  },
  "workers_dev": true,
  "preview_urls": true,
  "main": ".svelte-kit/cloudflare/_worker.js",
  "assets": {
    "binding": "ASSETS",
    "directory": ".svelte-kit/cloudflare"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
